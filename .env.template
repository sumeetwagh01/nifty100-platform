# Nifty 100 Financial Intelligence Platform — Environment Configuration Template
# Copy this file to .env and fill in values: cp config/.env.template .env
# .env is NOT committed to git (see .gitignore).

# --- Database ---
DB_PATH=data/nifty100.db

# --- API Server (FastAPI / Uvicorn) ---
PORT=8000
API_HOST=0.0.0.0

# --- Dashboard (Streamlit) ---
DASHBOARD_PORT=8501

# --- Logging ---
# One of: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# --- Data flags ---
# Set to true to display "SIMULATED DATA" badges on stock_prices / market_cap driven
# screens in the dashboard and reports (Section 14, Risk R-06).
SIMULATED_DATA_FLAG=true

# --- Paths to raw/supporting source files (read-only inputs) ---
RAW_DATA_DIR=data/raw
SUPPORTING_DATA_DIR=data/supporting

# --- Screener configuration ---
SCREENER_CONFIG_PATH=config/screener_config.yaml

# --- Data quality ---
DQ_LOG_PATH=validation_failures.csv
LOAD_AUDIT_PATH=load_audit.csv
